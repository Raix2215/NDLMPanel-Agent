# NDLMPanel Agent 环境变量配置
# 复制此文件为 .env 并填入真实值
# .env 已在 .gitignore 中，不会被提交

# LLM API 配置
NDLM_LLM_API_KEY=your-api-key-here
NDLM_LLM_BASE_URL=https://api.deepseek.com/v1
NDLM_LLM_MODEL_NAME=deepseek-chat

# 可选配置（有默认值）
# NDLM_LLM_MAX_TOKENS=65536
# NDLM_LLM_TEMPERATURE=0.7
# NDLM_MAX_TOOL_CALL_ROUNDS=10
# NDLM_AUDIT_LOG_DIRECTORY=./logs
# NDLM_CONTEXT_MAX_TOKENS=32000
# NDLM_CONTEXT_SESSION_TTL_SECONDS=1800
